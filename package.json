{
  "name": "commit-components",
  "displayName": "Commit Components",
  "description": "Commit Components enables you to write detailed commit messages, while leveraging the capabilities of git_components.yaml files",
  "version": "0.0.4",
  "publisher": "FeisarLabs",
  "repository": {
    "url": "https://github.com/Sinan-Karakaya/commit-components"
  },
  "keywords": [
    "git",
    "commit",
    "gitlint",
    "git_components",
    "components"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:commitComponents.openForm",
    "onCommand:commitComponents.setFooter"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitComponents.openForm",
        "title": "Commit Helper: Open Form",
        "icon": "$(edit)"
      },
      {
        "command": "commitComponents.setFooter",
        "title": "Commit Helper: Set Default Footer"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitComponents.openForm",
          "when": "scmProvider == git",
          "group": "navigation@100"
        }
      ],
      "scm/sourceControl": [
        {
          "command": "commitComponents.openForm",
          "when": "scmProvider == git",
          "group": "inline@100"
        }
      ]
    },
    "keybindings": [
      {
        "command": "commitComponents.openForm",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      }
    ],
    "configuration": {
      "title": "Commit Helper",
      "properties": {
        "commitComponents.footer": {
          "type": "string",
          "default": "",
          "description": "Default footer appended to generated commit messages."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "js-yaml": "^4.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}